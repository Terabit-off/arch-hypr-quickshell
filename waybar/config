{
"layer": "top",
"position": "top",

"margin": "5 15 0 15",

// что где расположено
"modules-left": [
    "hyprland/workspaces",
],
"modules-center": [
],
"modules-right": [
    "hyprland/language",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "battery",
    "tray",
    "clock",
],


"hyprland/language": {
    "format": "{}",
    "format-en": "EN",
    "format-ru": "RU",
  },

// звук
"pulseaudio": {
    "tooltip": false,

    "format": "{volume}% {icon}",
    "format-muted": "0% ",
    "format-icons": ["", " ", " "]
},





// wifi/lan
"network": {
    "tooltip": false,
    "format-wifi": "{essid} {signalStrength}%",
    //"format-ethernet": " {ifname}",
    "format-disconnected": "󰖪 ",
    "on-click": "~/scripts/wifi-menu.sh",
},

// CPU
"cpu": {
    "format": "CPU {usage}%",
    "interval": 2
},

// RAM
"memory": {
    "tooltip": false,
    "format": "RAM {used:0.1f}G",
    "interval": 5
},

// температура (по умолчанию возьмёт первый сенсор)
"temperature": {
    "tooltip": false,
    "critical-threshold": 80,
    "format": "{temperatureC}°C"
},

// яркость (работает с backlight/wlroots)
"backlight": {
    "format": "{percent}%  ",
    "device": "intel_backlight", // при необходимости поменяй на свой
    "tooltip": false,
},

// батарея
"battery": {
    "format": "{capacity}% {icon}",
    "format-charging": " {capacity}%",
    "format-full": " {capacity}% ",
    "format-icons": [" ", " ", " ", " ", " "],
    "tooltip": false,
},

// время + дата
"clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%d.%m.%Y %A}</big>"
},

"tray": {
    "icon-size": 13,
    "spacing": 10
},

}

